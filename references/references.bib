@article{liWastewaterbasedEpidemiologyPredicts2023,
  title = {Wastewater-Based Epidemiology Predicts {{COVID-19-induced}} Weekly New Hospital Admissions in over 150 {{USA}} Counties},
  author = {Li, Xuan and Liu, Huan and Gao, Li and Sherchan, Samendra P. and Zhou, Ting and Khan, Stuart J. and Van Loosdrecht, Mark C. M. and Wang, Qilin},
  year = {2023},
  month = jul,
  journal = {Nature Communications},
  volume = {14},
