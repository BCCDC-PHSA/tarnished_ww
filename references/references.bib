@incollection{macielSalmonellaEntericaLatency2017,
  title = {Salmonella Enterica: {{Latency}}},
  shorttitle = {Salmonella Enterica},
  booktitle = {Current {{Topics}} in {{Salmonella}} and {{Salmonellosis}}},
  author = {Maciel, Bianca Mendes and Rezende, Rachel Passos and Sriranganathan, Nammalwar and Maciel, Bianca Mendes and Rezende, Rachel Passos and Sriranganathan, Nammalwar},
  year = {2017},
  month = apr,
  publisher = {IntechOpen},
  doi = {10.5772/67173},
  urldate = {2024-01-23},
  abstract = {Infection caused by more than 1500 serotypes of Salmonella enterica subsp. enterica is one of the most common food-borne diseases, prevalent worldwide. Concerning public health, Salmonella latent carrier animals represent an important source of transmission of the disease. They are responsible for silent introduction of the bacteria into the food chain and the environment. Most pathogenesis studies of salmonellosis are focused on events that lead to clinical disease. Researchers have been unable to clearly discern the interaction between intracellular microorganisms and their resistant hosts in latency. However, understanding this interaction is essential for the proper employment of the control and eradication strategies. Thus, the objective of this article is to present an overview of some important events that occur during the infection cycle of S. enterica in latent carriers.},
  isbn = {978-953-51-3066-6},
  langid = {english}
}

