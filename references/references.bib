@article{altekruseSalmonellaEnteritidisBroiler2006,
  title = {Salmonella {{Enteritidis}} in {{Broiler Chickens}}, {{United States}}, 2000--2005},
  author = {Altekruse, Sean F. and Bauer, Nathan and Chanlongbutra, Amy and DeSagun, Robert and Naugle, Alecia and Schlosser, Wayne and Umholtz, Robert and White, Patricia},
